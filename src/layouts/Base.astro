---
import ThemeToggle from "@/components/ThemeToggle.vue";
import { HOME, withBase } from "@/lib/base";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "RFC Reader — search & read IETF RFCs",
  description = "A fast, minimalist, offline-friendly reader for IETF RFCs. Search thousands of RFCs and read them comfortably on any device.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Set the theme before first paint to avoid a flash. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var dark = stored
            ? stored === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {}
      })();
    </script>

    <link rel="icon" href={withBase("favicon.svg")} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={withBase("icons/apple-touch-icon.png")} />
    <link rel="manifest" href={withBase("manifest.webmanifest")} />
    <meta name="theme-color" content="#0b0f14" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="RFC Reader" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    <link rel="sitemap" href={withBase("sitemap-index.xml")} />
  </head>

  <body class="min-h-dvh">
    <a
      href="#main"
      class="sr-only focus:not-sr-only left-3 top-3 z-50 rounded-lg bg-accent px-3 py-2 text-sm text-accent-fg"
    >
      Skip to content
    </a>

    <header class="sticky top-0 z-20 border-b border-border bg-bg/85 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-5xl items-center gap-3 px-4">
        <a href={HOME} class="flex items-center gap-2 font-semibold text-fg">
          <span
            class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-accent font-mono text-xs font-bold text-accent-fg"
            aria-hidden="true">§</span
          >
          <span>RFC Reader</span>
        </a>
        <nav class="ml-auto flex items-center gap-2">
          <a
            href="https://github.com/meysam81/rfcreader"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-surface text-fg hover:bg-elevated"
            aria-label="Source on GitHub"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .5a12 12 0 0 0-3.79 23.4c.6.1.82-.26.82-.58v-2c-3.34.73-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.1-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.32.47-2.39 1.24-3.23-.13-.3-.54-1.52.12-3.17 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.87.12 3.17.77.84 1.23 1.91 1.23 3.23 0 4.62-2.8 5.64-5.48 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.82.57A12 12 0 0 0 12 .5Z"
              ></path>
            </svg>
          </a>
          <ThemeToggle client:load />
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
      <slot />
    </main>

    <footer class="mt-12 border-t border-border">
      <div class="mx-auto max-w-5xl px-4 py-6 text-sm text-muted">
        <p>
          RFC text is fetched live from the
          <a class="text-accent underline underline-offset-2" href="https://www.rfc-editor.org"
            >RFC Editor</a
          > and mirrors. This is an independent reader, not affiliated with the IETF.
        </p>
      </div>
    </footer>

    <script>
      import { registerSW } from "virtual:pwa-register";
      registerSW({ immediate: true });
    </script>
  </body>
</html>
